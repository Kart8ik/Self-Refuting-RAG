# SR-RAG Configuration Environment Variables

# Primary Groq API Key used by default for LLM inference
GROQ_API_KEY=your_groq_api_key_here

# Optional additional Groq keys for UI key-switching.
# The app discovers keys named GROQ_API_KEY_* and lets you switch between them.
GROQ_API_KEY_1=your_second_groq_api_key_here
GROQ_API_KEY_2=your_third_groq_api_key_here

# Optional: default selected key name on startup (must match one of the defined names).
# If omitted, GROQ_API_KEY is used.
SR_RAG_ACTIVE_GROQ_KEY_NAME=GROQ_API_KEY

# Fallback OpenAI API Key (optional - depending on fallback_model in config.yaml)
# OPENAI_API_KEY=your_openai_api_key_here
